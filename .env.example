# Copie este arquivo para ".env.local" e preencha com as chaves do seu projeto Supabase
# (Project Settings > API no painel do Supabase)

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Chave "service_role" — NUNCA exponha no frontend, usada apenas nas rotas de API do servidor
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role
